# Compose-local defaults. Split per-service examples live in deploy/env/*.env.example.

# postgres service
POSTGRES_USER=msp
POSTGRES_PASSWORD=msp
POSTGRES_DB=msp
POSTGRES_PORT=55432

# goose migrate service
GOOSE_DRIVER=postgres
GOOSE_DBSTRING=postgres://msp:msp@postgres:5432/msp?sslmode=disable
GOOSE_MIGRATION_DIR=/migrations

# api service
API_DATABASE_URL=postgres://msp:msp@postgres:5432/msp?sslmode=disable
API_RABBITMQ_URL=amqp://msp:msp@rabbitmq:5672/
API_HTTP_PORT=8080
API_PUBLIC_URL=http://localhost:8080
RUN_MIGRATIONS=1
MIGRATIONS_DIR=/app/migrations
GOOGLE_MAPS_API_KEY=
GOOGLE_PLACES_BASE_URL=https://places.googleapis.com

# ai-crawler worker service
WORKER_DATABASE_URL=postgres://msp:msp@postgres:5432/msp
WORKER_RABBITMQ_URL=amqp://msp:msp@rabbitmq:5672/
WORKER_PREFETCH=1
SINK=postgres

# normalize service
LLM_BASE_URL=https://api.deepseek.com
LLM_API_KEY=
LLM_MODEL=deepseek-chat
LLM_MIN_CONFIDENCE=0.7
LLM_TIMEOUT_S=20
LLM_MAX_TOKENS=120
LLM_MAX_CALLS_PER_SOURCE=80
NORMALIZE_WORKERS=1
NORMALIZE_SWEEP_INTERVAL_S=300
NORMALIZE_SWEEP_LIMIT=20

# frontend image build
FRONTEND_API_BASE_URL=http://localhost:8080/api/v1
FRONTEND_PUBLIC_URL=http://localhost:3000
