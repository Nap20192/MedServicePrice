{
  "comment": "Importable RabbitMQ topology for MedServicePrice. Load via: rabbitmqadmin import definitions.json  OR  Management UI > Overview > Import definitions. vhost '/'.",
  "vhosts": [
    { "name": "/" }
  ],
  "exchanges": [
    {
      "name": "medprice.events",
      "vhost": "/",
      "type": "topic",
      "durable": true,
      "auto_delete": false,
      "internal": false,
      "arguments": {}
    },
    {
      "name": "medprice.dlx",
      "vhost": "/",
      "type": "topic",
      "durable": true,
      "auto_delete": false,
      "internal": false,
      "arguments": {}
    }
  ],
  "queues": [
    {
      "name": "q.adapter.create",
      "vhost": "/",
      "durable": true,
      "auto_delete": false,
      "arguments": {
        "x-dead-letter-exchange": "medprice.dlx",
        "x-dead-letter-routing-key": "dlq.adapter.create"
      }
    },
    {
      "name": "q.adapter.fetch",
      "vhost": "/",
      "durable": true,
      "auto_delete": false,
      "arguments": {
        "x-dead-letter-exchange": "medprice.dlx",
        "x-dead-letter-routing-key": "dlq.adapter.fetch"
      }
    },
    {
      "name": "q.dead_letter",
      "vhost": "/",
      "durable": true,
      "auto_delete": false,
      "arguments": {}
    }
  ],
  "bindings": [
    {
      "source": "medprice.events",
      "vhost": "/",
      "destination": "q.adapter.create",
      "destination_type": "queue",
      "routing_key": "adapter.create",
      "arguments": {}
    },
    {
      "source": "medprice.events",
      "vhost": "/",
      "destination": "q.adapter.fetch",
      "destination_type": "queue",
      "routing_key": "adapter.fetch",
      "arguments": {}
    },
    {
      "source": "medprice.dlx",
      "vhost": "/",
      "destination": "q.dead_letter",
      "destination_type": "queue",
      "routing_key": "dlq.#",
      "arguments": {}
    }
  ]
}
