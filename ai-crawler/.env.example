# Secrets and local overrides. Copy to .env for local use.

# -- worker (RabbitMQ + Postgres sink). CLI ignores these. --------------------
RABBITMQ_URL=amqp://msp:msp@localhost:5672/
DATABASE_URL=postgres://msp:msp@localhost:55432/msp
WORKER_PREFETCH=1
WORKER_DECLARE_TOPOLOGY=1
# where fetched rows land: postgres (worker) | jsonl (CLI) | both
SINK=postgres

# Strong adapter discovery profile: slower, but keeps more candidate data URLs.
MAX_DEPTH=7
MAX_PAGES=3000
CONCURRENCY=24
FETCH_CONCURRENCY=24
PAGE_TIMEOUT_MS=60000
AGENT_BATCH_SIZE=12
AGENT_LINKS_PER_PAGE=90
REDISCOVER=1
ADAPTER_COMPACT=0
ADAPTER_LISTING_ROW_THRESHOLD=8
DISCOVERY_CITY_SLUGS=astana,almaty,aktau,aktobe,atyrau,karaganda,kostanay,pavlodar,saran,semey,shymkent,taraz,uralsk,oskemen
INVITRO_SEED_PATHS=/analizes/for-doctors/,/analizes/profi/


# LLM provider keys. Set one of these if LLM schema induction is enabled.
LLM_API_KEY=
DEEPSEEK_API_KEY=
GEMINI_API_KEY=
GOOGLE_API_KEY=
OPENAI_API_KEY=

# Optional LLM override. Schema induction is OFF by default (deterministic
# extractors are faster and reliable). Set LLM_SCHEMA_GEN=1 to enable for hard sites.
LLM_MODEL=deepseek-v4-flash
LLM_PROVIDER=openai/deepseek-v4-flash
LLM_BASE_URL=https://api.deepseek.com
LLM_SCHEMA_GEN=1
SCHEMA_GEN_MAX_PER_DOMAIN=8

# Debug browser visibility. Keep 0 for normal runs.
BROWSER_VISIBLE=0
BROWSER_VERBOSE=0

# Optional Playwright MCP adapter fallback. Requires Node.js/npm.
MCP_ENABLED=0
MCP_VISIBLE=0
MCP_HEADLESS=1
MCP_BROWSER=chrome
MCP_OUTPUT_DIR=.mcp-output
MCP_OUTPUT_MODE=file
MCP_CAPS=network
MCP_SNAPSHOT_MODE=full
MCP_CONSOLE_LEVEL=warning
MCP_TIMEOUT_S=45
MCP_TIMEOUT_ACTION_MS=10000
MCP_TIMEOUT_NAVIGATION_MS=60000
MCP_VIEWPORT_SIZE=1366x900
MCP_ALLOWED_ORIGINS=
MCP_ALLOWED_HOSTS=localhost,127.0.0.1
MCP_BLOCK_SERVICE_WORKERS=1
MCP_ISOLATED=1
MCP_SAVE_SESSION=1
MCP_IMAGE_RESPONSES=omit
MCP_CODEGEN=none
MCP_IGNORE_HTTPS_ERRORS=1
# empty: never feed this .env (LLM keys) into the MCP browser
MCP_SECRETS_FILE=

# Prompt logs are marked with PROMPT_BEGIN / PROMPT_BODY / PROMPT_END.
LOG_PROMPTS=1
LOG_PROMPTS_FULL=1
PROMPT_LOG_MAX_CHARS=6000

# Example: force a single fixed output path instead of per-domain output.
# OUTPUT_PATH=prices.jsonl
